# Supabase Configuration
# Create a Supabase project at https://supabase.com
# Copy these values from Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_DEFAULT_PROJECT_ID=your-project-id-here

# Optional: Service role key for admin operations (never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional E2E smoke credentials (Playwright)
E2E_USER_EMAIL=E2E@user.com
E2E_USER_PASSWORD=123456789
E2E_OBRA_ID=998c22ae-2342-4ca2-ba49-a911d8316bac
